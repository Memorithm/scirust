# Build artifacts
/target/
examples/benchmarks/target/
# scirust-burn-bridge is excluded from the root workspace (it pulls in the real
# Burn crate), so it builds into its own target dir.
scirust-burn-bridge/target/
Cargo.lock
*.rlib
*.so
*.dylib
*.dll

# Compiled binaries (no compiled artifacts in git)
scirust-rustc-driver/scirustc
scirust-rustc-driver/test
scirust-rustc-driver/target/
*.exe
*.out
# Stray test binaries once committed at the repo root — never re-add them.
/cliptest
/cliptest2

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Data
/data/
*.bin
*.tar.gz
*.zip

# TurboQuant
.turboquant-backup/
turboquant/
scripts/turboquant-*.sh
systemd/turboquant-*.service

# Cache
.fastembed_cache/

# Logs
*.log

# Temp
*.tmp
*.bak
*.lock

# CycloneDX SBOMs: cargo-cyclonedx writes one next to every workspace member.
# Only the curated facade SBOM under docs/sbom/ is tracked.
*.cdx.json
!docs/sbom/*.cdx.json

# Bundles d'évidence du banc O1 sur Jetson (scripts/bench-o1-jetson.sh) :
# les chiffres sont reportés dans paper/PAPER_PLAN.md et LIVESTATE.md,
# le bundle brut reste sur la machine de mesure.
bench-o1-jetson-*/

# The fuzz harness is its own cargo workspace and builds into its own target dir.
fuzz/target/
