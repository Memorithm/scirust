pub trait Optimizer {
    fn step(&mut self, tape: &mut crate::autodiff::reverse::Tape);
    fn set_lr(&mut self, lr: f32);
    fn lr(&self) -> f32;
}

pub struct Adam {
    pub lr: f32,
    pub beta1: f64,
    pub beta2: f64,
    pub eps: f64,
    pub t: usize,
}

impl Adam {
    pub fn new(lr: f32) -> Self {
        Self { lr, beta1: 0.9, beta2: 0.999, eps: 1e-8, t: 0 }
    }
}

impl Optimizer for Adam {
    fn step(&mut self, _tape: &mut crate::autodiff::reverse::Tape) {
        self.t += 1;
        // stub
    }
    fn set_lr(&mut self, lr: f32) { self.lr = lr; }
    fn lr(&self) -> f32 { self.lr }
}

/// Helper : applique un LrSchedule à un Optimizer pour le step donné.
pub fn apply_schedule<S: crate::autodiff::scheduler::LrSchedule, O: Optimizer>(
    sched: &S,
    opt: &mut O,
    step: usize,
) {
    opt.set_lr(sched.lr_at(step));
}
